{
  "build": {
    "core": "stm32",
    "cpu": "cortex-m4",
    "extra_flags": "-DSTM32G4 -DSTM32G473xx -DARDUINO_GENERIC_G473RCTX",
    "f_cpu": "170000000L",
    "framework_extra_flags": {
      "arduino": "-DCUSTOM_PERIPHERAL_PINS"
    },
    "mcu": "stm32g473rct6",
    "product_line": "STM32G473xx",
    "variant": "STM32G4xx/G473R(B-C-E)T_G474R(B-C-E)T_G483RET_G484RET"
  },
  "debug": {
    "default_tools": ["stlink"],
    "jlink_device": "STM32G473RC",
    "openocd_target": "stm32g4x",
    "svd_path": "STM32G474xx.svd"
  },
  "frameworks": ["arduino", "cmsis", "stm32cube"],
  "name": "STM32G473RC",
  "upload": {
    "maximum_ram_size": 131072,
    "maximum_size": 262144,
    "protocol": "stlink",
    "protocols": ["stlink", "jlink", "cmsis-dap", "blackmagic", "dfu"]
  },
  "url": "https://www.st.com/en/microcontrollers-microprocessors/stm32g473rc.html",
  "vendor": "ST"
}